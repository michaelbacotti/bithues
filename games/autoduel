<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Autoduel — Web Remake</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #0d0d0d; overflow: hidden; font-family: 'Courier New', monospace; }
  canvas { display: block; }
  #overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.85); display: none; z-index: 100;
    color: #f0f0f0; overflow-y: auto;
  }
  #overlay.active { display: flex; align-items: center; justify-content: center; }
  .town-panel {
    background: #111; border: 2px solid #4444aa; border-radius: 4px;
    padding: 24px; min-width: 480px; max-width: 600px; width: 90%;
  }
  .town-panel h2 { color: #4444aa; text-align: center; margin-bottom: 16px; font-size: 20px; letter-spacing: 2px; }
  .tabs { display: flex; gap: 4px; margin-bottom: 16px; }
  .tab {
    flex: 1; padding: 8px; text-align: center; cursor: pointer;
    background: #222; border: 1px solid #444; color: #888; font-size: 13px;
  }
  .tab.active { background: #333; color: #f0f0f0; border-color: #4444aa; }
  .tab:hover:not(.active) { background: #2a2a2a; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { color: #4444aa; border-bottom: 1px solid #333; padding: 6px 4px; text-align: left; }
  td { padding: 6px 4px; border-bottom: 1px solid #1a1a1a; }
  tr:hover { background: #1a1a1a; }
  .btn {
    padding: 6px 14px; cursor: pointer; background: #222; border: 1px solid #444;
    color: #f0f0f0; font-family: inherit; font-size: 12px;
  }
  .btn:hover { background: #333; border-color: #4444aa; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-buy { border-color: #00aa44; color: #00aa44; }
  .btn-buy:hover:not(:disabled) { background: #0a2a10; }
  .btn-sell { border-color: #aa6600; color: #aa6600; }
  .btn-sell:hover:not(:disabled) { background: #2a1a00; }
  .close-btn { float: right; cursor: pointer; color: #666; font-size: 18px; }
  .close-btn:hover { color: #f0f0f0; }
  .stat-bar { height: 8px; background: #222; border: 1px solid #333; margin-top: 3px; }
  .stat-fill { height: 100%; }
  .money { color: #f0c000; font-size: 15px; text-align: right; margin-bottom: 12px; }
  .cargo-row { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }
  .cargo-name { flex: 1; font-size: 12px; color: #aaa; }
  .cargo-qty { font-size: 12px; color: #f0f0f0; width: 40px; text-align: center; }
  .garage-item { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid #1a1a1a; }
  .garage-name { flex: 1; font-size: 12px; color: #ccc; }
  .garage-equipped { color: #4444aa; font-size: 11px; }
  .equipped-tag { color: #00aa44; font-size: 11px; }
  #start-screen {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: #0d0d0d; display: flex; flex-direction: column;
    align-items: center; justify-content: center; z-index: 200;
  }
  #start-screen h1 { font-size: 48px; color: #00aa00; letter-spacing: 6px; margin-bottom: 8px; text-shadow: 0 0 20px #00aa0066; }
  #start-screen .sub { color: #666; font-size: 14px; margin-bottom: 40px; letter-spacing: 3px; }
  #start-screen .info { color: #444; font-size: 12px; margin-bottom: 8px; max-width: 500px; text-align: center; line-height: 1.6; }
  #start-btn { padding: 14px 40px; font-size: 16px; background: #111; border: 2px solid #00aa00; color: #00aa00; cursor: pointer; font-family: inherit; letter-spacing: 3px; margin-top: 30px; }
  #start-btn:hover { background: #0a2a0a; }
  #gameover-screen {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.9); display: none; flex-direction: column;
    align-items: center; justify-content: center; z-index: 200; color: #f0f0f0;
  }
  #gameover-screen.active { display: flex; }
  #gameover-screen h2 { font-size: 36px; color: #cc2200; margin-bottom: 20px; }
  #gameover-screen p { color: #888; margin-bottom: 8px; }
  #restart-btn { padding: 12px 30px; font-size: 14px; background: #111; border: 2px solid #00aa00; color: #00aa00; cursor: pointer; font-family: inherit; margin-top: 20px; }
  #restart-btn:hover { background: #0a2a0a; }
</style>
</head>
<body>

<div id="start-screen">
  <h1>AUTODUEL</h1>
  <div class="sub">ORIGIN SYSTEMS 1984 — WEB REMAKE</div>
  <div class="info">Drive weaponized cars across a wasteland road network. Fight enemies. Salvage scrap. Trade goods. Upgrade your ride. Survive.</div>
  <div class="info">WASD or Arrow Keys to drive &bull; SPACE to fire<br>Drive into a blue town zone to trade &bull; Destroy enemies for scrap and money</div>
  <button id="start-btn" onclick="startGame()">J O I N &nbsp; T H E &nbsp; R O A D</button>
</div>

<div id="gameover-screen">
  <h2>WRECKED</h2>
  <p id="go-stats"></p>
  <button id="restart-btn" onclick="restartGame()">TRY AGAIN</button>
</div>

<canvas id="c"></canvas>

<div id="overlay">
  <div class="town-panel">
    <span class="close-btn" onclick="closeTown()">&times;</span>
    <h2 id="town-name">TOWN</h2>
    <div class="money">CREDITS: <span id="town-money">0</span></div>
    <div class="tabs">
      <div class="tab active" onclick="switchTab('buy')">BUY</div>
      <div class="tab" onclick="switchTab('sell')">SELL</div>
      <div class="tab" onclick="switchTab('garage')">GARAGE</div>
    </div>
    <div id="tab-buy" class="tab-content active"></div>
    <div id="tab-sell" class="tab-content"></div>
    <div id="tab-garage" class="tab-content"></div>
  </div>
</div>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

// ─── CONSTANTS ───────────────────────────────────────────────────────────────
const WORLD_W = 3000, WORLD_H = 2000;
const ROAD_W = 80;
const BASE_PRICES = {
  machineGun: 500,  armor: 300,  fuel: 20,  repairKit: 80,
  scrap: 30,       cargo: 100
};

// ─── GAME STATE ──────────────────────────────────────────────────────────────
let gameState = 'start'; // start | playing | town | gameover
let tick = 0;
let screenShake = 0;
let player, enemies, bullets, particles, towns, roads, projectiles;
let keys = {};
let currentTown = null;
let cam = { x: 0, y: 0 };

// ─── TOWNS ────────────────────────────────────────────────────────────────────
const TOWN_DEFS = [
  { name: 'BARREN ROCK',  x: 200,  y: 500,  w: 180, h: 160,
    buyMult:  { machineGun: 1.3, armor: 0.8, fuel: 0.6, repairKit: 1.0 },
    sellMult: { scrap: 1.2, cargo: 0.7 } },
  { name: 'DUSTY SPUR',   x: 1200, y: 800,  w: 180, h: 160,
    buyMult:  { machineGun: 0.7, armor: 1.4, fuel: 1.1, repairKit: 0.9 },
    sellMult: { scrap: 0.9, cargo: 1.3 } },
  { name: 'NEW DENVER',   x: 600,  y: 1600, w: 180, h: 160,
    buyMult:  { machineGun: 1.0, armor: 1.0, fuel: 1.0, repairKit: 1.0 },
    sellMult: { scrap: 1.0, cargo: 1.0 } },
];

// ─── ROADS (waypoint pairs) ───────────────────────────────────────────────────
const ROAD_SEGS = [
  // Barren Rock ↔ Dusty Spur
  [{x:290,y:580},{x:700,y:640},{x:1100,y:720},{x:1200,y:800}],
  // Dusty Spur ↔ New Denver
  [{x:1200,y:800},{x:900,y:1100},{x:700,y:1400},{x:660,y:1600}],
  // Barren Rock ↔ New Denver
  [{x:290,y:580},{x:350,y:900},{x:420,y:1200},{x:550,y:1480},{x:660,y:1600}],
];

// ─── UTIL ─────────────────────────────────────────────────────────────────────
function lerp(a,b,t) { return a+(b-a)*t; }
function dist(a,b) { return Math.hypot(a.x-b.x,a.y-b.y); }
function rng(min,max) { return min+Math.random()*(max-min); }
function clamp(v,min,max) { return Math.max(min,Math.min(max,v)); }

function pointToSegment(p, a, b) {
  const dx = b.x-a.x, dy = b.y-a.y;
  const len2 = dx*dx+dy*dy;
  if (len2 === 0) return { t:0, d:dist(p,a), px:a.x, py:a.y };
  let t = ((p.x-a.x)*dx+(p.y-a.y)*dy)/len2;
  t = clamp(t,0,1);
  return { t, d: dist(p,{x:a.x+t*dx,y:a.y+t*dy}), px:a.x+t*dx, py:a.y+t*dy };
}

function distToRoad(p, segs) {
  let best = Infinity;
  for (const seg of segs) {
    for (let i = 0; i < seg.length-1; i++) {
      const r = pointToSegment(p, seg[i], seg[i+1]);
      if (r.d < best) best = r.d;
    }
  }
  return best;
}

function isOnRoad(p) { return distToRoad(p, ROAD_SEGS) < ROAD_W/2 + 10; }

function roadPos(p) {
  let best = Infinity, bx=p.x, by=p.y;
  for (const seg of ROAD_SEGS) {
    for (let i = 0; i < seg.length-1; i++) {
      const r = pointToSegment(p, seg[i], seg[i+1]);
      if (r.d < best) { best = r.d; bx = r.px; by = r.py; }
    }
  }
  return { x:bx, y:by, d:best };
}

// ─── CAR CLASS ────────────────────────────────────────────────────────────────
class Car {
  constructor(x, y, isPlayer) {
    this.x = x; this.y = y;
    this.vx = 0; this.vy = 0;
    this.angle = isPlayer ? 0 : rng(0, Math.PI*2);
    this.speed = 0;
    this.isPlayer = isPlayer;
    this.armor = isPlayer ? 100 : 80;
    this.maxArmor = this.armor;
    this.hull = isPlayer ? 100 : 60;
    this.maxHull = this.hull;
    this.fuel = 100;
    this.maxFuel = 100;
    this.alive = true;
    this.fireCooldown = 0;
    this.w = 30; this.h = 18;
    this.weapons = [{type:'machineGun',qty:1}];
    this.scrap = 0;
    this.cargo = { type:null, qty:0 };
    this.turnDir = 0;
    this.throttle = 0;
    this.color = isPlayer ? '#00aa00' : '#cc2200';
  }

  get maxSpeed() {
    const onRoad = isOnRoad(this);
    return onRoad ? 200 : 60;
  }
  get accel() { return isOnRoad(this) ? 120 : 40; }

  update(dt) {
    if (!this.alive) return;
    if (this.isPlayer) this._control(dt);
    else this._ai(dt);

    // Physics
    const drag = 0.97;
    this.vx *= drag; this.vy *= drag;
    const ax = Math.cos(this.angle) * this.throttle * this.accel * dt;
    const ay = Math.sin(this.angle) * this.throttle * this.accel * dt;
    this.vx += ax; this.vy += ay;

    // Off-road drag
    if (!isOnRoad(this)) { this.vx *= 0.92; this.vy *= 0.92; }

    // Clamp speed
    const spd = Math.hypot(this.vx, this.vy);
    if (spd > this.maxSpeed) { this.vx = this.vx/spd*this.maxSpeed; this.vy = this.vy/spd*this.maxSpeed; }
    this.speed = spd;

    this.x = clamp(this.x + this.vx*dt, this.w, WORLD_W - this.w);
    this.y = clamp(this.y + this.vy*dt, this.h, WORLD_H - this.h);

    // Fuel
    if (this.throttle > 0) this.fuel -= this.throttle * 8 * dt;
    this.fuel = Math.max(0, this.fuel);
    if (this.fuel <= 0) { this.throttle = 0; }

    // Cooldown
    if (this.fireCooldown > 0) this.fireCooldown -= dt;
  }

  _control(dt) {
    const turn = Math.min(1, this.speed / 60);
    if (keys['ArrowLeft']  || keys['KeyA']) this.angle -= 2.5 * turn * dt;
    if (keys['ArrowRight'] || keys['KeyD']) this.angle += 2.5 * turn * dt;
    this.throttle = 0;
    if (keys['ArrowUp']   || keys['KeyW']) this.throttle = 1;
    if (keys['ArrowDown'] || keys['KeyS']) this.throttle = -0.5;
    if ((keys['Space'] || keys['KeyX']) && this.fireCooldown <= 0) this.fire();
  }

  _ai(dt) {
    // Find nearest player or road target
    if (!player || !player.alive) return;
    const dx = player.x - this.x, dy = player.y - this.y;
    const d = Math.hypot(dx, dy);
    const tAngle = Math.atan2(dy, dx);

    // Turn toward player
    let diff = tAngle - this.angle;
    while (diff > Math.PI) diff -= Math.PI*2;
    while (diff < -Math.PI) diff += Math.PI*2;
    this.angle += clamp(diff, -2.0*dt, 2.0*dt);

    // Throttle
    this.throttle = d > 80 ? 0.9 : d < 40 ? -0.3 : 0.3;

    // Fire when in range and roughly aimed
    if (d < 250 && Math.abs(diff) < 0.4 && this.fireCooldown <= 0) this.fire();
  }

  fire() {
    if (this.fireCooldown > 0 || this.fuel <= 0) return;
    const w = { machineGun: 0.15, cannon: 0.8 }[this.weapons[0]?.type] || 0.15;
    this.fireCooldown = w;
    const spread = (Math.random()-0.5)*0.08;
    const bx = this.x + Math.cos(this.angle)*18;
    const by = this.y + Math.sin(this.angle)*18;
    bullets.push(new Bullet(bx, by, this.angle + spread, this.isPlayer));

    // Muzzle flash particle
    for (let i = 0; i < 3; i++)
      particles.push({ x:bx, y:by, vx: Math.cos(this.angle)*rng(20,60), vy: Math.sin(this.angle)*rng(20,60), life:0.12, color:'#ffff88', r:4, type:'flash' });
  }

  takeDamage(amount) {
    if (this.armor > 0) {
      const a = Math.min(this.armor, amount);
      this.armor -= a; amount -= a;
    }
    if (amount > 0) this.hull -= amount;
    if (this.isPlayer) screenShake = 0.3;
    if (this.hull <= 0) this.die();
  }

  die() {
    this.alive = false;
    // Explosion
    for (let i = 0; i < 20; i++) {
      const a = rng(0, Math.PI*2), sp = rng(30,120);
      particles.push({ x:this.x, y:this.y, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp,
        life: rng(0.4,1.0), color: ['#ff4400','#ff8800','#ffcc00','#444'][Math.floor(rng(0,4))],
        r: rng(3,8), type:'spark' });
    }
    // Drop scrap
    if (!this.isPlayer) {
      const scrapAmt = Math.floor(rng(2,7));
      particles.push({ x:this.x, y:this.y, vx:0, vy:0, life:999, scrapAmt,
        color:'#888', r:10, type:'scrap' });
      // Money drop
      const val = Math.floor(rng(50,150));
      player.money = (player.money||0) + val;
      particles.push({ x:this.x, y:this.y-20, vx:0, vy:-30, life:1.5,
        text:'+$'+val, color:'#f0c000', type:'text' });
    }
  }

  draw() {
    if (!this.alive) return;
    const sx = this.x - cam.x + canvas.width/2;
    const sy = this.y - cam.y + canvas.height/2;
    ctx.save();
    ctx.translate(sx, sy);
    ctx.rotate(this.angle);

    // Shadow
    ctx.fillStyle = 'rgba(0,0,0,0.3)';
    ctx.fillRect(-this.w/2+3, -this.h/2+3, this.w, this.h);

    // Body
    ctx.fillStyle = this.color;
    ctx.fillRect(-this.w/2, -this.h/2, this.w, this.h);

    // Front (darker)
    ctx.fillStyle = 'rgba(0,0,0,0.4)';
    ctx.fillRect(this.w/2-8, -this.h/2, 8, this.h);

    // Windshield
    ctx.fillStyle = 'rgba(100,200,255,0.3)';
    ctx.fillRect(this.w/2-10, -this.h/2+2, 5, this.h-4);

    // Gun barrel
    ctx.fillStyle = '#555';
    ctx.fillRect(this.w/2, -2, 8, 4);

    ctx.restore();
  }
}

// ─── BULLET / PROJECTILE ─────────────────────────────────────────────────────
class Bullet {
  constructor(x, y, angle, fromPlayer) {
    this.x = x; this.y = y;
    this.vx = Math.cos(angle)*380;
    this.vy = Math.sin(angle)*380;
    this.fromPlayer = fromPlayer;
    this.alive = true;
    this.r = 3;
  }
  update(dt) {
    this.x += this.vx*dt; this.y += this.vy*dt;
    if (this.x<0||this.x>WORLD_W||this.y<0||this.y>WORLD_H) this.alive=false;
  }
  draw() {
    const sx = this.x - cam.x + canvas.width/2;
    const sy = this.y - cam.y + canvas.height/2;
    ctx.fillStyle = '#ffff00';
    ctx.beginPath(); ctx.arc(sx,sy,this.r,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(255,255,0,0.3)';
    ctx.beginPath(); ctx.arc(sx,sy,this.r*2,0,Math.PI*2); ctx.fill();
  }
}

// ─── INIT ────────────────────────────────────────────────────────────────────
function init() {
  player = new Car(290, 560, true);
  player.money = 500;
  enemies = []; bullets = []; particles = [];
  towns = TOWN_DEFS.map(t => ({...t}));
  spawnEnemies(4);
}

function spawnEnemies(n) {
  for (let i = 0; i < n; i++) {
    const seg = ROAD_SEGS[Math.floor(Math.random()*ROAD_SEGS.length)];
    const pt = seg[Math.floor(rng(1, seg.length-1))];
    const e = new Car(pt.x + rng(-60,60), pt.y + rng(-60,60), false);
    e.money = 0;
    enemies.push(e);
  }
}

// ─── COLLISIONS ─────────────────────────────────────────────────────────────
function checkCollisions() {
  // Bullets vs cars
  for (const b of bullets) {
    if (!b.alive) continue;
    const targets = b.fromPlayer ? enemies : [player];
    for (const t of targets) {
      if (!t || !t.alive) continue;
      if (dist(b, t) < t.w/2) {
        t.takeDamage(b.fromPlayer ? 15 : 10);
        b.alive = false;
        // Hit spark
        for (let i=0;i<4;i++) {
          const a=rng(0,Math.PI*2), sp=rng(20,60);
          particles.push({ x:b.x,y:b.y, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp,
            life:0.15, color:'#ffff44', r:2, type:'spark' });
        }
        break;
      }
    }
  }

  // Car vs car
  const allCars = [player, ...enemies].filter(c => c && c.alive);
  for (let i = 0; i < allCars.length; i++) {
    for (let j = i+1; j < allCars.length; j++) {
      const a = allCars[i], b = allCars[j];
      const d = dist(a,b);
      const minD = 22;
      if (d < minD && d > 0) {
        const push = (minD - d) / 2;
        const nx = (b.x - a.x)/d, ny = (b.y - a.y)/d;
        a.x -= nx*push; a.y -= ny*push;
        b.x += nx*push; b.y += ny*push;
        const relSpd = Math.hypot(a.vx-a.vy,b.vx-b.vy);
        const dmg = relSpd * 0.1;
        if (dmg > 5) { a.takeDamage(dmg); b.takeDamage(dmg); }
      }
    }
  }

  // Scrap pickup
  if (!player.alive) return;
  for (let i = particles.length-1; i >= 0; i--) {
    const p = particles[i];
    if (p.type !== 'scrap') continue;
    if (dist(player, p) < 25) {
      player.scrap = (player.scrap||0) + p.scrapAmt;
      particles.splice(i,1);
    }
  }
}

// ─── TOWN SYSTEM ─────────────────────────────────────────────────────────────
function checkTown() {
  if (!player.alive) return;
  for (const t of towns) {
    if (player.x > t.x && player.x < t.x+t.w && player.y > t.y && player.y < t.y+t.h) {
      openTown(t); return;
    }
  }
}

function getPrice(town, item, buy) {
  const base = BASE_PRICES[item] || 0;
  const mult = buy
    ? (town.buyMult[item] || 1.0)
    : (town.sellMult[item] || 1.0);
  return Math.round(base * mult);
}

let activeTab = 'buy';

function switchTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[onclick="switchTab('${tab}')"]`).classList.add('active');
  document.getElementById(`tab-${tab}`).classList.add('active');
  renderTownUI();
}

function openTown(town) {
  currentTown = town;
  gameState = 'town';
  player.vx = 0; player.vy = 0; player.throttle = 0;
  renderTownUI();
  document.getElementById('overlay').classList.add('active');
}

function closeTown() {
  gameState = 'playing';
  currentTown = null;
  document.getElementById('overlay').classList.remove('active');
}

function renderTownUI() {
  if (!currentTown) return;
  document.getElementById('town-name').textContent = currentTown.name;
  document.getElementById('town-money').textContent = player.money||0;

  const bHtml = `
  <table>
    <tr><th>ITEM</th><th>PRICE</th><th>&nbsp;</th></tr>
    ${['machineGun','armor','fuel','repairKit'].map(item => {
      const price = getPrice(currentTown, item, true);
      const cantAfford = (player.money||0) < price;
      const label = {machineGun:'Machine Gun',armor:'Armor Plating',fuel:'Fuel (10u)',repairKit:'Repair Kit'}[item];
      return `<tr>
        <td>${label}</td><td style="color:#f0c000">$${price}</td>
        <td><button class="btn btn-buy" ${cantAfford?'disabled':''} onclick="townBuy('${item}',${price})">BUY</button></td>
      </tr>`;
    }).join('')}
  </table>`;

  const sHtml = `
  <table>
    <tr><th>ITEM</th><th>PRICE</th><th>&nbsp;</th></tr>
    ${(() => {
      const rows = [];
      const scrapAmt = player.scrap||0;
      if (scrapAmt > 0) {
        const price = getPrice(currentTown, 'scrap', false);
        rows.push(`<tr><td>Scrap (${scrapAmt})</td><td style="color:#f0c000">$${price} ea</td>
          <td><button class="btn btn-sell" onclick="townSell('scrap',${price})">SELL ALL</button></td></tr>`);
      }
      if (player.cargo.qty > 0) {
        const price = getPrice(currentTown, 'cargo', false);
        rows.push(`<tr><td>Cargo (${player.cargo.qty})</td><td style="color:#f0c000">$${price} ea</td>
          <td><button class="btn btn-sell" onclick="townSell('cargo',${price})">SELL ALL</button></td></tr>`);
      }
      if (rows.length === 0) rows.push('<tr><td colspan="3" style="color:#555">Nothing to sell</td></tr>');
      return rows.join('');
    })()}
  </table>`;

  const gHtml = `
  <div style="font-size:12px;color:#666;margin-bottom:10px;">CREDITS: <span style="color:#f0c000">$${player.money||0}</span> &nbsp;|&nbsp; SCRAP: ${player.scrap||0} &nbsp;|&nbsp; CARGO: ${player.cargo.qty||0}</div>
  <table>
    <tr><th>STAT</th><th>VALUE</th><th>REPAIR / RELOAD</th></tr>
    <tr>
      <td>Armor</td><td>${player.armor}/${player.maxArmor}</td>
      <td><button class="btn" onclick="repair('armor')">FIX ($${getPrice(currentTown,'repairKit',true)})</button></td>
    </tr>
    <tr>
      <td>Hull</td><td>${player.hull}/${player.maxHull}</td>
      <td><button class="btn" onclick="repair('hull')">FIX ($${getPrice(currentTown,'repairKit',true)})</button></td>
    </tr>
    <tr>
      <td>Fuel</td><td>${Math.floor(player.fuel)}/${player.maxFuel}</td>
      <td><button class="btn" onclick="refuel()">REFUEL ($${getPrice(currentTown,'fuel',true)})</button></td>
    </tr>
    <tr><td colspan="3" style="border:none;padding-top:12px;color:#4444aa;font-size:11px;">WEAPONS</td></tr>
    <tr>
      <td>Machine Gun</td><td style="color:#00aa44">EQUIPPED</td><td>—</td>
    </tr>
    <tr><td colspan="3" style="border:none;padding-top:12px;color:#4444aa;font-size:11px;">INVENTORY</td></tr>
    <tr><td colspan="3" style="color:#666;font-size:11px;">Scrap: ${player.scrap||0} &nbsp;|&nbsp; Cargo: ${player.cargo.qty||0}</td></tr>
  </table>`;

  document.getElementById('tab-buy').innerHTML = bHtml;
  document.getElementById('tab-sell').innerHTML = sHtml;
  document.getElementById('tab-garage').innerHTML = gHtml;
}

function townBuy(item, price) {
  if ((player.money||0) < price) return;
  player.money -= price;
  if (item === 'machineGun') { player.weapons = [{type:'machineGun',qty:1}]; }
  else if (item === 'armor') { player.armor = Math.min(player.maxArmor, player.armor + 40); }
  else if (item === 'repairKit') { /* consumed on use */ }
  else if (item === 'fuel') { player.fuel = Math.min(player.maxFuel, player.fuel + 30); }
  renderTownUI();
}

function townSell(item, price) {
  if (item === 'scrap') {
    const qty = player.scrap||0;
    if (qty <= 0) return;
    player.money += qty * price;
    player.scrap = 0;
  } else if (item === 'cargo') {
    const qty = player.cargo.qty||0;
    if (qty <= 0) return;
    player.money += qty * price;
    player.cargo = {type:null, qty:0};
  }
  renderTownUI();
}

function repair(which) {
  const price = getPrice(currentTown,'repairKit',true);
  if ((player.money||0) < price) return;
  if (player[which] >= (which === 'armor' ? player.maxArmor : player.maxHull)) return;
  player.money -= price;
  if (which === 'armor') player.armor = player.maxArmor;
  else player.hull = player.maxHull;
  renderTownUI();
}

function refuel() {
  const price = getPrice(currentTown,'fuel',true);
  if ((player.money||0) < price) return;
  player.money -= price;
  player.fuel = player.maxFuel;
  renderTownUI();
}

// ─── DRAW ─────────────────────────────────────────────────────────────────────
function drawWorld() {
  // Background
  ctx.fillStyle = '#1a3d1a';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  const ox = cam.x - canvas.width/2;
  const oy = cam.y - canvas.height/2;

  // World bounds
  ctx.fillStyle = '#111';
  ctx.fillRect(-ox, -oy, WORLD_W, WORLD_H);

  // Roads
  ctx.strokeStyle = '#5c4033';
  ctx.lineWidth = ROAD_W;
  ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  for (const seg of ROAD_SEGS) {
    ctx.beginPath();
    ctx.moveTo(seg[0].x-ox, seg[0].y-oy);
    for (let i=1;i<seg.length;i++) ctx.lineTo(seg[i].x-ox, seg[i].y-oy);
    ctx.stroke();
  }
  // Road markings
  ctx.strokeStyle = '#f0c000';
  ctx.lineWidth = 3;
  ctx.setLineDash([20,15]);
  for (const seg of ROAD_SEGS) {
    ctx.beginPath();
    ctx.moveTo(seg[0].x-ox, seg[0].y-oy);
    for (let i=1;i<seg.length;i++) ctx.lineTo(seg[i].x-ox, seg[i].y-oy);
    ctx.stroke();
  }
  ctx.setLineDash([]);
  // Edge lines
  ctx.strokeStyle = 'rgba(255,255,255,0.3)';
  ctx.lineWidth = 2;

  // Towns
  for (const t of towns) {
    const tx = t.x-ox, ty = t.y-oy;
    ctx.fillStyle = 'rgba(68,68,170,0.15)';
    ctx.fillRect(tx, ty, t.w, t.h);
    ctx.strokeStyle = '#4444aa';
    ctx.lineWidth = 2;
    ctx.strokeRect(tx, ty, t.w, t.h);
    ctx.fillStyle = '#4444aa';
    ctx.font = 'bold 11px Courier New';
    ctx.textAlign = 'center';
    ctx.fillText(t.name, tx+t.w/2, ty+t.h/2+4);
  }

  // Enemies
  for (const e of enemies) e.draw();

  // Player
  if (player.alive) player.draw();

  // Bullets
  for (const b of bullets) b.draw();

  // Particles
  for (const p of particles) {
    const px = (p.type === 'text' ? p.x : p.x) - ox;
    const py = (p.type === 'text' ? p.y : p.y) - oy;
    if (p.type === 'text') {
      ctx.font = 'bold 14px Courier New';
      ctx.fillStyle = p.color;
      ctx.globalAlpha = Math.min(1, p.life * 2);
      ctx.textAlign = 'center';
      ctx.fillText(p.text, px, py);
      ctx.globalAlpha = 1;
    } else {
      ctx.globalAlpha = Math.min(1, p.life * 3);
      ctx.fillStyle = p.color;
      ctx.beginPath(); ctx.arc(px, py, p.r, 0, Math.PI*2); ctx.fill();
      ctx.globalAlpha = 1;
    }
  }
}

function drawHUD() {
  const W = canvas.width, H = canvas.height;
  const pad = 12, barW = 160, barH = 10;

  // HUD background strip
  ctx.fillStyle = 'rgba(17,17,17,0.85)';
  ctx.fillRect(0, 0, W, 52);
  ctx.strokeStyle = '#333';
  ctx.lineWidth = 1;
  ctx.strokeRect(0, 0, W, 52);

  let y = pad;

  // Armor bar
  ctx.fillStyle = '#888'; ctx.font = '11px Courier New'; ctx.textAlign = 'left';
  ctx.fillText('ARMOR', pad, y+10);
  ctx.fillStyle = '#222'; ctx.fillRect(pad+50, y+1, barW, barH);
  const aPct = player.armor/player.maxArmor;
  ctx.fillStyle = aPct>0.5?'#00cc44':aPct>0.25?'#cccc00':'#cc0000';
  ctx.fillRect(pad+50, y+1, barW*aPct, barH);
  ctx.fillStyle = '#fff'; ctx.font = '9px Courier New';
  ctx.fillText(`${Math.ceil(player.armor)}/${player.maxArmor}`, pad+52, y+10);

  // Hull bar
  y += 16;
  ctx.fillStyle = '#888'; ctx.font = '11px Courier New';
  ctx.fillText('HULL', pad, y+10);
  ctx.fillStyle = '#222'; ctx.fillRect(pad+50, y+1, barW, barH);
  const hPct = player.hull/player.maxHull;
  ctx.fillStyle = hPct>0.5?'#00cc44':hPct>0.25?'#cccc00':'#cc0000';
  ctx.fillRect(pad+50, y+1, barW*hPct, barH);
  ctx.fillStyle = '#fff'; ctx.font = '9px Courier New';
  ctx.fillText(`${Math.ceil(player.hull)}/${player.maxHull}`, pad+52, y+10);

  // Fuel bar
  y += 16;
  ctx.fillStyle = '#888'; ctx.font = '11px Courier New';
  ctx.fillText('FUEL', pad, y+10);
  ctx.fillStyle = '#222'; ctx.fillRect(pad+50, y+1, barW, barH);
  ctx.fillStyle = '#0088ff';
  ctx.fillRect(pad+50, y+1, barW*(player.fuel/player.maxFuel), barH);
  ctx.fillStyle = '#fff'; ctx.font = '9px Courier New';
  ctx.fillText(`${Math.floor(player.fuel)}/${player.maxFuel}`, pad+52, y+10);

  // Money
  ctx.fillStyle = '#f0c000'; ctx.font = 'bold 13px Courier New'; ctx.textAlign = 'right';
  ctx.fillText(`$${player.money||0}`, W-pad, 24);

  // Speed
  ctx.fillStyle = '#888'; ctx.font = '11px Courier New';
  ctx.fillText(`SPD: ${Math.floor(player.speed)}`, W-pad, 40);

  // Scrap/cargo
  ctx.fillStyle = '#666'; ctx.font = '10px Courier New'; ctx.textAlign = 'right';
  ctx.fillText(`SCRAP:${player.scrap||0}  CARGO:${player.cargo.qty||0}`, W-pad, 52);

  // Controls hint (fade out after 5 seconds)
  if (tick < 300) {
    ctx.globalAlpha = tick < 240 ? 1 : (300-tick)/60;
    ctx.fillStyle = '#444'; ctx.font = '10px Courier New'; ctx.textAlign = 'center';
    ctx.fillText('WASD/Arrows: Drive  |  SPACE: Fire  |  Enter towns to trade', W/2, H-14);
    ctx.globalAlpha = 1;
  }
}

function drawMinimap() {
  const W = canvas.width, H = canvas.height;
  const mx = W-118, my = 62, mw = 108, mh = 72;
  const sx = mw/WORLD_W, sy = mh/WORLD_H;

  ctx.fillStyle = 'rgba(17,17,17,0.85)';
  ctx.fillRect(mx-2, my-2, mw+4, mh+4);
  ctx.strokeStyle = '#333'; ctx.lineWidth = 1;
  ctx.strokeRect(mx-2, my-2, mw+4, mh+4);

  // Roads
  ctx.strokeStyle = '#5c4033'; ctx.lineWidth = 4;
  for (const seg of ROAD_SEGS) {
    ctx.beginPath();
    ctx.moveTo(mx+seg[0].x*sx, my+seg[0].y*sy);
    for (let i=1;i<seg.length;i++) ctx.lineTo(mx+seg[i].x*sx, my+seg[i].y*sy);
    ctx.stroke();
  }

  // Towns
  ctx.fillStyle = '#4444aa';
  for (const t of towns) {
    ctx.fillRect(mx+t.x*sx-1, my+t.y*sy-1, 4, 4);
  }

  // Enemies
  ctx.fillStyle = '#cc2200';
  for (const e of enemies) {
    if (!e.alive) continue;
    ctx.fillRect(mx+e.x*sx-1, my+e.y*sy-1, 3, 3);
  }

  // Player
  if (player.alive) {
    ctx.fillStyle = '#00aa00';
    ctx.beginPath(); ctx.arc(mx+player.x*sx, my+player.y*sy, 3, 0, Math.PI*2); ctx.fill();
  }
}

// ─── GAME LOOP ────────────────────────────────────────────────────────────────
let lastTime = 0;
function loop(ts) {
  const dt = Math.min((ts - lastTime)/1000, 0.05);
  lastTime = ts;
  tick++;

  if (gameState === 'playing') {
    // Update
    if (player.alive) player.update(dt);
    for (const e of enemies) if (e.alive) e.update(dt);
    for (const b of bullets) b.update(dt);
    bullets = bullets.filter(b => b.alive);
    for (const p of particles) {
      p.x += (p.vx||0)*dt; p.y += (p.vy||0)*dt;
      if (p.vx !== undefined) p.vx *= 0.95;
      if (p.vy !== undefined) p.vy *= 0.95;
      if (p.type !== 'scrap') p.life -= dt;
      if (p.type === 'text') p.vy += 40*dt;
    }
    particles = particles.filter(p => p.life > 0 || p.type === 'scrap');

    checkCollisions();
    checkTown();

    // Respawn enemies
    const alive = enemies.filter(e => e.alive).length;
    if (alive < 3 && tick % 600 === 0) spawnEnemies(1);

    // Camera
    if (player.alive) { cam.x = player.x; cam.y = player.y; }

    // Screen shake
    if (screenShake > 0) {
      ctx.save();
      ctx.translate(rng(-screenShake*5, screenShake*5), rng(-screenShake*5, screenShake*5));
      screenShake -= dt*2;
    }

    // Draw
    drawWorld();
    drawHUD();
    drawMinimap();

    if (screenShake > 0) ctx.restore();

    // Game over check
    if (!player.alive && gameState !== 'gameover') {
      setTimeout(() => {
        gameState = 'gameover';
        document.getElementById('go-stats').textContent = `Survived ${Math.floor(tick/60)} seconds | $${player.money||0} earned`;
        document.getElementById('gameover-screen').classList.add('active');
      }, 1200);
    }
  }

  requestAnimationFrame(loop);
}

// ─── INPUT ────────────────────────────────────────────────────────────────────
window.addEventListener('keydown', e => {
  keys[e.code] = true;
  if (e.code === 'Escape' && gameState === 'town') closeTown();
  if (e.code === 'Space') e.preventDefault();
});
window.addEventListener('keyup', e => { keys[e.code] = false; });

// ─── RESIZE ───────────────────────────────────────────────────────────────────
function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
window.addEventListener('resize', resize);

// ─── START / RESTART ─────────────────────────────────────────────────────────
function startGame() {
  document.getElementById('start-screen').style.display = 'none';
  gameState = 'playing';
  init();
  requestAnimationFrame(loop);
}

function restartGame() {
  document.getElementById('gameover-screen').classList.remove('active');
  gameState = 'playing';
  tick = 0;
  init();
}

resize();
</script>
