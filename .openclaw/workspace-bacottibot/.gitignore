# Ignore .openclaw internals we DON'T want tracked
!.gitignore

.openclaw/*/
.openclaw/*.log
.openclaw/*.json
.openclaw/canvas/
.openclaw/completions/
.openclaw/credentials/
.openclaw/cache/
.openclaw/media/
.openclaw/tasks/

# Large binaries
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.heic
*.psd
*.tiff
*.zip
*.pages
*.numbers
*.xlsx
*.tar.gz

# OS files
.DS_Store
.Trashes
._*

# DEFAULT: ignore everything
*

# Re-allow workspace directories and files
# (must come AFTER * to override it)
!skills/
!memory/
!References/
!SOP_Folder/
!Reports/
!scripts/
!.learnings/

# Re-allow specific file types
!*.md
!*.py
!*.sh
!*.json
