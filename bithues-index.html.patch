        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        function shuffleFeatured() {
            const container = document.getElementById('featured-reviews');
            const shuffled = shuffleArray([...allBooks]).slice(0, 3);
            container.innerHTML = shuffled.map(book => {
                const densityDots = '<span class="density-dot"></span>'.repeat(book.density);
                return '<div class="review-card"><div class="review-meta"><span class="review-tag">' + book.category + '</span><span class="review-time">' + book.time + '</span><span class="review-idea-density">' + densityDots + '</span></div><h3><a href="' + book.url + '">' + book.title + '</a></h3><p class="author">by ' + book.author + '</p><p class="tldr">' + book.tldr + '</p></div>';
            }).join('');
        }

        shuffleFeatured();
